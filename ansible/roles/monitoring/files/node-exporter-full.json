{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "type": "stat",
      "title": "Hosts up",
      "id": 1,
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": "Prometheus",
      "targets": [
        { "refId": "A", "expr": "count(up{job=\"node\"} == 1)" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ {"color":"red","value":null},{"color":"green","value":1} ] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "area" }
    },
    {
      "type": "stat",
      "title": "Hosts down",
      "id": 2,
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": "Prometheus",
      "targets": [
        { "refId": "A", "expr": "count(up{job=\"node\"} == 0) OR vector(0)" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ {"color":"green","value":null},{"color":"red","value":1} ] }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" }
    },
    {
      "type": "timeseries",
      "title": "CPU usage (%)",
      "id": 3,
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 4 },
      "datasource": "Prometheus",
      "targets": [
        { "refId": "A", "expr": "100 - (avg by (host) (rate(node_cpu_seconds_total{mode=\"idle\"}[2m])) * 100)", "legendFormat": "{{host}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 } }
    },
    {
      "type": "timeseries",
      "title": "Memory used (%)",
      "id": 4,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": "Prometheus",
      "targets": [
        { "refId": "A", "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100", "legendFormat": "{{host}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 } }
    },
    {
      "type": "timeseries",
      "title": "Disk used (%) — /",
      "id": 5,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": "Prometheus",
      "targets": [
        { "refId": "A", "expr": "(1 - (node_filesystem_avail_bytes{mountpoint=\"/\"} / node_filesystem_size_bytes{mountpoint=\"/\"})) * 100", "legendFormat": "{{host}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 } }
    },
    {
      "type": "timeseries",
      "title": "Network RX (bits/s)",
      "id": 6,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": "Prometheus",
      "targets": [
        { "refId": "A", "expr": "rate(node_network_receive_bytes_total{device!~\"lo|docker.*|veth.*|cni.*|flannel.*\"}[2m]) * 8", "legendFormat": "{{host}} {{device}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "bps" } }
    },
    {
      "type": "timeseries",
      "title": "Network TX (bits/s)",
      "id": 7,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "datasource": "Prometheus",
      "targets": [
        { "refId": "A", "expr": "rate(node_network_transmit_bytes_total{device!~\"lo|docker.*|veth.*|cni.*|flannel.*\"}[2m]) * 8", "legendFormat": "{{host}} {{device}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "bps" } }
    },
    {
      "type": "timeseries",
      "title": "Load average (1m)",
      "id": 8,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "datasource": "Prometheus",
      "targets": [
        { "refId": "A", "expr": "node_load1", "legendFormat": "{{host}}" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Temperature (°C)",
      "id": 9,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "datasource": "Prometheus",
      "targets": [
        { "refId": "A", "expr": "node_hwmon_temp_celsius", "legendFormat": "{{host}} {{chip}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "celsius" } }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["picluster", "nodes"],
  "templating": { "list": [] },
  "time": { "from": "now-3h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "PiCluster - Nodes Overview",
  "uid": "picluster-nodes",
  "version": 1,
  "weekStart": ""
}
