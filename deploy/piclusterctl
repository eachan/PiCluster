#!/usr/bin/env python3
"""
piclusterctl - one-stop CLI for the PiCluster supervisor.

Examples:

    # Pull latest from git and run the full Ansible site playbook.
    piclusterctl deploy

    # Same, but only the storage/samba bits.
    piclusterctl deploy --tags storage,samba

    # Skip the git pull (use local checkout).
    piclusterctl deploy --no-pull

    # Status across all hosts (uptime, k3s, samba, ollama, storage).
    piclusterctl status

    # Run a one-off command across every cluster host.
    piclusterctl run --target cluster -- df -h /mnt/storage

    # SSH helper.
    piclusterctl ssh node-2

    # Tail the deployment log.
    piclusterctl logs
"""
from __future__ import annotations

import argparse
import getpass
import os
import re
import shutil
import subprocess
import sys
import tempfile
import time
from pathlib import Path
from typing import Any

PROJECT_ROOT = Path(os.environ.get("PICLUSTER_ROOT", "/opt/picluster")).resolve()
ANSIBLE_DIR = PROJECT_ROOT / "ansible"
INVENTORY = ANSIBLE_DIR / "inventory" / "hosts.yml"
LOG_FILE = Path(os.environ.get("PICLUSTER_LOG", "/var/log/picluster-deploy.log"))
SSH_USER = os.environ.get("PICLUSTER_SSH_USER", "eachan")

C = {
    "reset": "\033[0m", "bold": "\033[1m", "dim": "\033[2m",
    "blue": "\033[34m", "green": "\033[32m", "yellow": "\033[33m",
    "red": "\033[31m", "cyan": "\033[36m",
}
USE_COLOR = sys.stdout.isatty()


def color(name: str, text: str) -> str:
    if not USE_COLOR:
        return text
    return f"{C.get(name, '')}{text}{C['reset']}"


def info(msg: str) -> None:
    print(color("cyan", "==>"), msg)


def warn(msg: str) -> None:
    print(color("yellow", "[warn]"), msg)


def fail(msg: str, code: int = 1) -> None:
    print(color("red", "[error]"), msg, file=sys.stderr)
    sys.exit(code)


def run(cmd: list[str], check: bool = True, cwd: Path | None = None,
        capture: bool = False, env: dict | None = None) -> subprocess.CompletedProcess:
    info(color("dim", "$ " + " ".join(cmd)))
    return subprocess.run(cmd, check=check, cwd=cwd,
                          text=True,
                          capture_output=capture,
                          env={**os.environ, **(env or {})})


def log_to_file(line: str) -> None:
    try:
        LOG_FILE.parent.mkdir(parents=True, exist_ok=True)
        with LOG_FILE.open("a") as f:
            f.write(line.rstrip() + "\n")
    except OSError:
        pass


def _read_group_var(name: str) -> Any:
    """Read a single top-level variable from ansible/group_vars/all.yml.

    Ansible *should* load that file automatically, but if its variable
    precedence rules don't propagate `ansible_become_password` to the play
    for some reason (different inventory layout, /etc/ansible/ansible.cfg
    on the host, etc.), we still want deploys to be non-interactive. So we
    parse the file directly here and pass key auth values through to
    ansible-playbook explicitly.
    """
    path = ANSIBLE_DIR / "group_vars" / "all.yml"
    if not path.exists():
        return None
    try:
        import yaml  # provided by Ansible's own dependencies
    except ImportError:
        return None
    try:
        data = yaml.safe_load(path.read_text(encoding="utf-8")) or {}
    except yaml.YAMLError:
        return None
    return data.get(name) if isinstance(data, dict) else None


# ---------------------------------------------------------------------------
# deploy
# ---------------------------------------------------------------------------
def cmd_deploy(args: argparse.Namespace) -> int:
    if not ANSIBLE_DIR.is_dir():
        fail(f"Ansible directory not found at {ANSIBLE_DIR} - is PiCluster cloned?")

    ts = time.strftime("%Y-%m-%dT%H:%M:%S")
    log_to_file(f"\n===== deploy {ts} target={args.target} tags={args.tags} =====")

    if not args.no_pull:
        branch = args.branch or "main"
        info(f"Syncing {PROJECT_ROOT} to origin/{branch}…")
        run(["git", "fetch", "--all", "--prune"], cwd=PROJECT_ROOT)
        # /opt/picluster is a *deployed* clone, not a workspace - we always
        # want the working tree to match the remote exactly, so a hard reset
        # is correct here. (Use `git -C /opt/picluster <cmd>` if you really
        # need to keep local edits.)
        run(["git", "reset", "--hard", f"origin/{branch}"], cwd=PROJECT_ROOT)
        run(["git", "clean", "-fdx",
             "--exclude=local/", "--exclude=.venv/", "--exclude=dashboard/.venv/"],
            cwd=PROJECT_ROOT)
    else:
        warn("--no-pull: using current local checkout")

    if not shutil.which("ansible-playbook"):
        fail("ansible-playbook is not installed. Run scripts/bootstrap-supervisor.sh first.")

    cmd: list[str] = [
        "ansible-playbook",
        "-i", str(INVENTORY),
        "site.yml",
    ]
    if args.tags:
        cmd += ["--tags", args.tags]
    if args.skip_tags:
        cmd += ["--skip-tags", args.skip_tags]
    if args.target:
        cmd += ["--limit", args.target]
    if args.check:
        cmd += ["--check", "--diff"]
    if args.ask_pass:
        cmd += ["--ask-pass"]
    if args.ask_become_pass:
        cmd += ["--ask-become-pass"]
    if args.verbose:
        cmd += ["-" + "v" * min(args.verbose, 4)]

    # If group_vars/all.yml has a become password, surface it via the official
    # ANSIBLE_BECOME_PASSWORD_FILE env var. Using a 0600 temp file avoids
    # putting the password on the command line.
    extra_env: dict[str, str] = {}
    pw_file: Path | None = None
    if not args.ask_become_pass:
        become_pw = _read_group_var("ansible_become_password")
        if become_pw:
            fd, p = tempfile.mkstemp(prefix="picluster-become-", suffix=".txt")
            try:
                with os.fdopen(fd, "w") as fh:
                    fh.write(str(become_pw))
                os.chmod(p, 0o600)
                pw_file = Path(p)
                extra_env["ANSIBLE_BECOME_PASSWORD_FILE"] = str(pw_file)
                info(color("dim", "(using become password from group_vars/all.yml)"))
            except Exception:
                if Path(p).exists():
                    Path(p).unlink()

    try:
        rc = run(cmd, cwd=ANSIBLE_DIR, env=extra_env, check=False).returncode
    finally:
        if pw_file and pw_file.exists():
            pw_file.unlink()
    log_to_file(f"deploy finished rc={rc}")
    if rc == 0:
        info(color("green", "Deploy completed successfully."))
    elif rc == 4:  # ansible's "all hosts unreachable" exit code
        warn(f"Deploy returned exit code {rc} (hosts unreachable).")
        print()
        print(color("yellow", "Looks like Ansible can't SSH into the hosts."))
        print("If you haven't yet, distribute the supervisor's SSH key:")
        print(color("cyan", "    piclusterctl setup-keys"))
        print("Or run a one-off deploy with interactive password prompts:")
        print(color("cyan", "    piclusterctl deploy --ask-pass --ask-become-pass"))
    else:
        warn(f"Deploy returned exit code {rc}")
    return rc


# ---------------------------------------------------------------------------
# setup-keys - distribute supervisor's SSH key to every host
# ---------------------------------------------------------------------------
def _list_inventory_hosts() -> list[str]:
    """Return the set of hostnames in the Ansible inventory."""
    try:
        out = subprocess.check_output(
            ["ansible", "all", "-i", str(INVENTORY), "--list-hosts"],
            text=True, stderr=subprocess.DEVNULL,
        )
    except (subprocess.CalledProcessError, FileNotFoundError):
        # fall back to a sensible default
        return ["supervisor", "node-1", "node-2", "node-3", "ai"]
    hosts: list[str] = []
    for line in out.splitlines():
        line = line.strip()
        if not line or line.startswith("hosts ") or line.endswith(":"):
            continue
        if re.match(r"^[A-Za-z0-9._-]+$", line):
            hosts.append(line)
    return hosts


def _ssh_works(host: str, key: Path | None = None) -> bool:
    cmd = [
        "ssh",
        "-o", "BatchMode=yes",
        "-o", "ConnectTimeout=3",
        "-o", "StrictHostKeyChecking=accept-new",
        "-o", "UserKnownHostsFile=" + str(Path.home() / ".ssh" / "known_hosts"),
    ]
    if key:
        cmd += ["-i", str(key), "-o", "IdentitiesOnly=yes"]
    cmd += [f"{SSH_USER}@{host}", "true"]
    return subprocess.run(cmd, capture_output=True).returncode == 0


def cmd_setup_keys(args: argparse.Namespace) -> int:
    ssh_dir = Path.home() / ".ssh"
    ssh_dir.mkdir(mode=0o700, exist_ok=True)
    key_path = ssh_dir / "id_ed25519"
    pub_path = key_path.with_suffix(".pub")

    if not key_path.exists():
        info("Generating an ed25519 SSH key for this user…")
        subprocess.check_call([
            "ssh-keygen", "-t", "ed25519", "-N", "",
            "-f", str(key_path), "-C", "picluster-supervisor",
        ])

    pub_key = pub_path.read_text().strip()
    hosts = args.hosts or _list_inventory_hosts()

    info(f"Target hosts: {' '.join(hosts)}")
    info(f"Public key   : {pub_key.split()[1][:16]}…  ({pub_path})")
    print()

    already_ok: list[str] = []
    need_copy: list[str] = []
    for h in hosts:
        if _ssh_works(h, key=key_path):
            print(f"  {color('green', 'ok ')}  {h:<14}  key already works")
            already_ok.append(h)
        else:
            need_copy.append(h)

    if not need_copy:
        info(color("green", "All hosts reachable with the SSH key. Nothing to do."))
        return 0

    print()
    use_sshpass = shutil.which("sshpass") is not None
    password = args.password or os.environ.get("PICLUSTER_SSH_PASSWORD")
    if not use_sshpass:
        warn("sshpass not installed (try: sudo apt install -y sshpass). "
             "Falling back to manual mode.")

    if use_sshpass and not password:
        try:
            password = getpass.getpass(f"SSH password for {SSH_USER}: ")
        except EOFError:
            password = None

    failed: list[str] = []
    for h in need_copy:
        if use_sshpass and password:
            info(f"Copying key to {h}…")
            rc = subprocess.call([
                "sshpass", "-p", password,
                "ssh-copy-id",
                "-o", "StrictHostKeyChecking=accept-new",
                "-i", str(pub_path),
                f"{SSH_USER}@{h}",
            ])
            if rc == 0 and _ssh_works(h, key=key_path):
                print(f"  {color('green', 'ok ')}  {h:<14}  key installed")
                continue
            warn(f"  could not push key to {h} via password "
                 f"(rc={rc}). Falling back to manual.")
        failed.append(h)

    if failed:
        print()
        warn("Could not automatically install the key on these hosts:")
        for h in failed:
            print(f"   - {h}")
        print()
        print("Run this command (or paste the key) on each remaining host:")
        print()
        print(color("cyan",
                    "  mkdir -p ~/.ssh && chmod 700 ~/.ssh && \\\n"
                    f"    echo '{pub_key}' >> ~/.ssh/authorized_keys && \\\n"
                    "    chmod 600 ~/.ssh/authorized_keys"))
        print()
        warn("Then re-run: piclusterctl setup-keys  (to verify)")
        return 1

    info(color("green", "All hosts now reachable via SSH key."))
    return 0


# ---------------------------------------------------------------------------
# status
# ---------------------------------------------------------------------------
def cmd_status(_: argparse.Namespace) -> int:
    if not shutil.which("ansible"):
        fail("ansible is not installed.")

    info("Pinging hosts…")
    run(["ansible", "all", "-i", str(INVENTORY), "-m", "ping",
         "--one-line"], cwd=ANSIBLE_DIR, check=False)

    info("Uptime + load:")
    run(["ansible", "all", "-i", str(INVENTORY),
         "-a", "uptime", "--one-line"],
        cwd=ANSIBLE_DIR, check=False)

    info("Disk usage (root + storage):")
    run(["ansible", "all", "-i", str(INVENTORY),
         "-a", "df -h --output=target,size,used,avail,pcent / /mnt/storage 2>/dev/null || df -h /",
         "--one-line"],
        cwd=ANSIBLE_DIR, check=False)

    info("K3s nodes (from supervisor's kubeconfig, if present):")
    kc = Path.home() / ".kube" / "config"
    if kc.exists() and shutil.which("kubectl"):
        run(["kubectl", "--kubeconfig", str(kc), "get", "nodes", "-o", "wide"], check=False)
    else:
        warn("kubectl/kubeconfig not available on this host yet.")
    return 0


# ---------------------------------------------------------------------------
# run (ad-hoc command)
# ---------------------------------------------------------------------------
def cmd_run(args: argparse.Namespace) -> int:
    target = args.target or "all"
    if not args.command:
        fail("missing command after --")
    info(f"Running on {target}: {' '.join(args.command)}")
    rc = run(["ansible", target, "-i", str(INVENTORY),
              "-a", " ".join(args.command), "--one-line"],
             cwd=ANSIBLE_DIR, check=False).returncode
    return rc


# ---------------------------------------------------------------------------
# ssh
# ---------------------------------------------------------------------------
def cmd_ssh(args: argparse.Namespace) -> int:
    return run(["ssh", f"{SSH_USER}@{args.host}", *args.extra], check=False).returncode


# ---------------------------------------------------------------------------
# logs
# ---------------------------------------------------------------------------
def cmd_logs(args: argparse.Namespace) -> int:
    if not LOG_FILE.exists():
        warn(f"No log file at {LOG_FILE}")
        return 0
    if args.follow:
        return subprocess.run(["tail", "-F", str(LOG_FILE)]).returncode
    return subprocess.run(["tail", f"-n{args.lines}", str(LOG_FILE)]).returncode


# ---------------------------------------------------------------------------
# version
# ---------------------------------------------------------------------------
def cmd_version(_: argparse.Namespace) -> int:
    sha = "unknown"
    try:
        sha = subprocess.check_output(["git", "-C", str(PROJECT_ROOT),
                                       "rev-parse", "--short", "HEAD"],
                                      text=True).strip()
    except subprocess.CalledProcessError:
        pass
    print(f"piclusterctl 1.0.0 (commit {sha}, root {PROJECT_ROOT})")
    return 0


# ---------------------------------------------------------------------------
def build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(prog="piclusterctl",
                                description="Manage the PiCluster from the supervisor node.")
    sub = p.add_subparsers(dest="cmd", required=True)

    d = sub.add_parser("deploy", help="git pull + ansible-playbook site.yml")
    d.add_argument("--no-pull", action="store_true", help="skip git pull")
    d.add_argument("--branch", help="git branch to deploy (default: main)")
    d.add_argument("--tags", help="ansible --tags list (comma separated)")
    d.add_argument("--skip-tags", help="ansible --skip-tags list")
    d.add_argument("--target", help="limit to host or group (e.g. node-1 / cluster)")
    d.add_argument("--check", action="store_true", help="run in --check --diff mode")
    d.add_argument("--ask-pass", action="store_true",
                   help="prompt for the SSH password (passes --ask-pass to ansible)")
    d.add_argument("--ask-become-pass", action="store_true",
                   help="prompt for the sudo password")
    d.add_argument("-v", "--verbose", action="count", default=0)
    d.set_defaults(func=cmd_deploy)

    k = sub.add_parser("setup-keys",
                       help="distribute this host's SSH key to every node (one-time)")
    k.add_argument("--password", help="SSH password (else $PICLUSTER_SSH_PASSWORD or prompted)")
    k.add_argument("--hosts", nargs="*",
                   help="optional explicit host list (default: inventory)")
    k.set_defaults(func=cmd_setup_keys)

    s = sub.add_parser("status", help="show cluster + node status")
    s.set_defaults(func=cmd_status)

    r = sub.add_parser("run", help="run an ad-hoc shell command on hosts")
    r.add_argument("--target", default="all")
    r.add_argument("command", nargs=argparse.REMAINDER,
                   help="command after -- (e.g. -- df -h)")
    r.set_defaults(func=cmd_run)

    sh = sub.add_parser("ssh", help="ssh into a host as the SSH user")
    sh.add_argument("host")
    sh.add_argument("extra", nargs=argparse.REMAINDER)
    sh.set_defaults(func=cmd_ssh)

    lg = sub.add_parser("logs", help="show deployment log")
    lg.add_argument("-f", "--follow", action="store_true")
    lg.add_argument("-n", "--lines", type=int, default=200)
    lg.set_defaults(func=cmd_logs)

    v = sub.add_parser("version", help="print version")
    v.set_defaults(func=cmd_version)
    return p


def main(argv: list[str] | None = None) -> int:
    parser = build_parser()
    args = parser.parse_args(argv)
    try:
        return args.func(args)
    except KeyboardInterrupt:
        warn("interrupted")
        return 130
    except subprocess.CalledProcessError as e:
        fail(f"command failed (rc={e.returncode})")


if __name__ == "__main__":
    sys.exit(main())
