# Force LF endings for everything Linux consumes - prevents Windows commits
# from producing CRLF files that wouldn't run on the supervisor.
* text=auto eol=lf

*.sh        text eol=lf
*.py        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.j2        text eol=lf
*.conf      text eol=lf
*.service   text eol=lf
*.timer     text eol=lf

# Scripts we want to stay executable in the worktree
deploy/piclusterctl              text eol=lf
scripts/bootstrap-supervisor.sh  text eol=lf

# Binary-ish things
*.png  binary
*.jpg  binary
*.ico  binary
